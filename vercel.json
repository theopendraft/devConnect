{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/posts.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  }
}